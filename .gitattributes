# Normaliza line endings para LF no repositório
* text=auto eol=lf

# Arquivos explicitamente de texto
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.env*  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binários (não mexe)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary

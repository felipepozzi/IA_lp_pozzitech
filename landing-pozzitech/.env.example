PORT=2999

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic ────────────────────────────────────────────────
# Encontre em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelo padrão (haiku = mais barato; sonnet = mais capaz)
# claude-haiku-4-5-20251001 | claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Chatbot ───────────────────────────────────────────────────
# Slug do projeto na tabela `projects` (deve existir no Supabase)
CHATBOT_PROJECT_SLUG=pozzitech

# ── Resend — email de resumo para o lead ─────────────────────
# Encontre em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remetente verificado no Resend (domínio deve estar configurado)
RESEND_FROM=PozziTech <noreply@pozzitech.com.br>
# Email que recebe notificação quando um novo lead é capturado
RESEND_NOTIFY_EMAIL=felipe@pozzitech.com.br

# ── n8n — webhook pós-captura de lead ────────────────────────
# Produção (workflow ativado):   https://n8n.seudominio.com/webhook/lead-captured
# Teste (sem ativar workflow):   https://n8n.seudominio.com/webhook-test/lead-captured
N8N_WEBHOOK_URL=http://localhost:5678/webhook/lead-captured

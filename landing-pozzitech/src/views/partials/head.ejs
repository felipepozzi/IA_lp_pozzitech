<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary SEO -->
  <title><%= meta.title %></title>
  <meta name="description" content="<%= meta.description %>" />
  <meta name="keywords" content="<%= meta.keywords %>" />
  <meta name="author" content="PozziTech" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="<%= meta.url %>" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= meta.url %>" />
  <meta property="og:title" content="<%= meta.title %>" />
  <meta property="og:description" content="<%= meta.description %>" />
  <meta property="og:image" content="<%= meta.image %>" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="PozziTech" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= meta.title %>" />
  <meta name="twitter:description" content="<%= meta.description %>" />
  <meta name="twitter:image" content="<%= meta.image %>" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%234F46E5'/><text x='16' y='22' font-size='18' text-anchor='middle' fill='white' font-family='Inter'>P</text></svg>" />

  <!-- Performance: Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Google Fonts: Inter -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />

  <!-- Main CSS -->
  <link rel="stylesheet" href="/css/style.css" />

  <!-- Schema Markup: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PozziTech",
    "url": "<%= meta.url %>",
    "description": "<%= meta.description %>",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "availableLanguage": "Portuguese"
    },
    "offers": {
      "@type": "Offer",
      "name": "Diagnóstico Gratuito de Automação com IA",
      "price": "0",
      "priceCurrency": "BRL",
      "description": "Sessão gratuita de 30 minutos para mapear oportunidades de automação com IA na sua empresa."
    }
  }
  </script>

  <!-- Schema Markup: Service -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Diagnóstico Gratuito de Automação com IA",
    "provider": {
      "@type": "Organization",
      "name": "PozziTech"
    },
    "description": "Sessão gratuita de 30 minutos onde mapeamos seus processos, identificamos gargalos e apresentamos as principais oportunidades de automação com IA.",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "BRL"
    }
  }
  </script>
  <!-- Meta Pixel noscript fallback (imagem 1x1 para navegadores sem JS) -->
  <noscript>
    <img height="1" width="1" style="display:none"
         src="https://www.facebook.com/tr?id=1991499815072883&ev=PageView&noscript=1" />
  </noscript>
</head>

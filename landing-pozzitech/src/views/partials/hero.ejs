<section id="hero" class="relative min-h-screen flex items-center overflow-hidden" style="background: #0A0A0A; min-height: 100svh;">

  <!-- Background orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div style="position:absolute;top:-10%;left:20%;width:600px;height:600px;background:radial-gradient(circle,rgba(79,70,229,0.18) 0%,transparent 70%);border-radius:50%;"></div>
    <div style="position:absolute;bottom:-10%;right:10%;width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,0.12) 0%,transparent 70%);border-radius:50%;"></div>
    <div style="position:absolute;top:40%;left:-5%;width:400px;height:400px;background:radial-gradient(circle,rgba(34,197,94,0.06) 0%,transparent 70%);border-radius:50%;"></div>
    <!-- Grid pattern -->
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:60px 60px;"></div>
  </div>

  <div class="max-w-container mx-auto px-6 pt-32 pb-20 lg:py-40 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center w-full relative z-10">

    <!-- Left: Copy -->
    <div>
      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] tracking-tight mb-6">
        Sua empresa perde R$15 mil/mês em tarefas que
        <span class="gradient-text"> a IA resolve</span>
        em segundos.
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-white/60 leading-relaxed mb-10 max-w-lg">
        Empresas como a sua economizam 120h e R$15 mil/mês automatizando atendimento, vendas e backoffice com IA. Em 30 minutos, mostramos exatamente onde você está perdendo.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a href="#offer" class="btn-primary text-base justify-center">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Descubra onde sua empresa perde dinheiro — grátis
        </a>
        <a href="https://wa.me/<%= whatsapp.number %>?text=<%= encodeURIComponent(whatsapp.message) %>"
           target="_blank" rel="noopener"
           class="btn-secondary justify-center">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Tirar Dúvidas no WhatsApp
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap gap-6 text-sm text-white/40">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-highlight" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Resultados no 1º mês
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-highlight" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Diagnóstico gratuito · 30 min
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-highlight" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Sem compromisso
        </span>
      </div>
    </div>

    <!-- Right: Visual -->
    <div class="relative flex items-center justify-center lg:justify-end animate-float">
      <div class="relative w-full max-w-lg">

        <!-- Main dashboard card -->
        <div class="rounded-2xl border border-white/10 p-1 shadow-glow" style="background:rgba(17,24,39,0.8);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);">
          <!-- Card header -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/10">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
            </div>
            <span class="text-xs text-white/40 ml-2 font-mono">automacao-dashboard.ai</span>
          </div>

          <!-- Dashboard content -->
          <div class="p-5 space-y-4">
            <!-- KPIs row -->
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-xl p-3 text-center" style="background:rgba(79,70,229,0.15);border:1px solid rgba(79,70,229,0.3);">
                <div class="text-xl font-bold text-white">-40%</div>
                <div class="text-xs text-white/50 mt-0.5">Custos ops</div>
              </div>
              <div class="rounded-xl p-3 text-center" style="background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.3);">
                <div class="text-xl font-bold text-highlight">3x</div>
                <div class="text-xs text-white/50 mt-0.5">Velocidade</div>
              </div>
              <div class="rounded-xl p-3 text-center" style="background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.3);">
                <div class="text-xl font-bold text-white">98%</div>
                <div class="text-xs text-white/50 mt-0.5">Satisfação</div>
              </div>
            </div>

            <!-- Chart area -->
            <div class="rounded-xl p-4" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium text-white/60">Processos Automatizados</span>
                <span class="text-xs text-highlight font-semibold">+248 este mês</span>
              </div>
              <!-- Bar chart SVG -->
              <svg viewBox="0 0 280 80" class="w-full h-16">
                <defs>
                  <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#4F46E5"/>
                    <stop offset="100%" stop-color="#4F46E5" stop-opacity="0.3"/>
                  </linearGradient>
                </defs>
                <!-- Bars -->
                <rect x="5" y="55" width="22" height="25" rx="4" fill="url(#barGrad)" opacity="0.5"/>
                <rect x="35" y="45" width="22" height="35" rx="4" fill="url(#barGrad)" opacity="0.6"/>
                <rect x="65" y="38" width="22" height="42" rx="4" fill="url(#barGrad)" opacity="0.7"/>
                <rect x="95" y="30" width="22" height="50" rx="4" fill="url(#barGrad)" opacity="0.75"/>
                <rect x="125" y="20" width="22" height="60" rx="4" fill="url(#barGrad)" opacity="0.85"/>
                <rect x="155" y="10" width="22" height="70" rx="4" fill="url(#barGrad)"/>
                <rect x="185" y="5" width="22" height="75" rx="4" fill="#4F46E5"/>
                <rect x="215" y="2" width="22" height="78" rx="4" fill="#4F46E5"/>
                <rect x="245" y="0" width="22" height="80" rx="4" fill="#22C55E"/>
              </svg>
            </div>

            <!-- Automation flow -->
            <div class="flex items-center gap-2 overflow-hidden">
              <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(79,70,229,0.2);">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
              </div>
              <div class="h-px flex-1" style="background:linear-gradient(90deg,rgba(79,70,229,0.5),rgba(79,70,229,0.1))"></div>
              <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(124,58,237,0.2);">
                <svg class="w-4 h-4" style="color:#a78bfa" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div class="h-px flex-1" style="background:linear-gradient(90deg,rgba(124,58,237,0.5),rgba(34,197,94,0.3))"></div>
              <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(34,197,94,0.2);">
                <svg class="w-4 h-4 text-highlight" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-xs text-white/40 ml-1 flex-shrink-0">Automação ativa</span>
            </div>
          </div>
        </div>

        <!-- Floating mini cards -->
        <div class="absolute -top-8 -right-4 rounded-xl px-4 py-3 shadow-lg border border-white/10 hidden sm:block" style="background:rgba(17,24,39,0.9);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full flex items-center justify-center bg-highlight/20">
              <svg class="w-4 h-4 text-highlight" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <div class="text-xs text-white font-semibold">Lead capturado</div>
              <div class="text-xs text-white/40">há 2 segundos</div>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-6 -left-4 rounded-xl px-4 py-3 shadow-lg border border-white/10 hidden sm:block" style="background:rgba(17,24,39,0.9);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background:rgba(79,70,229,0.2);">
              <svg class="w-4 h-4 text-accent-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
              <div class="text-xs text-white font-semibold">+120h economizadas</div>
              <div class="text-xs text-white/40">este mês</div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30 text-xs">
    <span>Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
  </div>
</section>

<section id="use-cases" class="py-24 lg:py-32 bg-surface">
  <div class="max-w-container mx-auto px-6">

    <div class="max-w-3xl mx-auto text-center mb-16 reveal">
      <div class="section-tag">Casos de uso</div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary leading-tight tracking-tight mb-6">
        Já ajudamos empresas como a sua. Veja como funciona no seu setor:
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed">
        Seja qual for o seu negócio, existem processos que podem — e devem — ser automatizados. Veja como funciona na prática.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Case 1 -->
      <div class="card reveal group" style="transition-delay:0ms">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl" style="background:#F0FDF4;">🏥</div>
          <div>
            <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Clínicas e Saúde</div>
            <h3 class="text-lg font-bold text-primary mb-2">Agendamento e lembretes automáticos</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Pacientes agendam 24/7 pelo WhatsApp. O sistema confirma, envia lembretes e gerencia cancelamentos sem nenhuma secretária envolvida.
            </p>
            <div class="mt-4 flex gap-2 flex-wrap">
              <span class="px-2 py-1 rounded-md text-xs font-medium text-emerald-700 bg-emerald-50">-80% no-show</span>
              <span class="px-2 py-1 rounded-md text-xs font-medium text-emerald-700 bg-emerald-50">24/7 disponível</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Case 2 -->
      <div class="card reveal group" style="transition-delay:100ms">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl" style="background:#EFF6FF;">🛒</div>
          <div>
            <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">E-commerce e Varejo</div>
            <h3 class="text-lg font-bold text-primary mb-2">SAC e pós-venda automatizados</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Status de pedido, trocas, devoluções e dúvidas frequentes respondidas automaticamente. Sua equipe só lida com casos complexos.
            </p>
            <div class="mt-4 flex gap-2 flex-wrap">
              <span class="px-2 py-1 rounded-md text-xs font-medium text-blue-700 bg-blue-50">-60% tickets</span>
              <span class="px-2 py-1 rounded-md text-xs font-medium text-blue-700 bg-blue-50">Resposta em 3s</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Case 3 -->
      <div class="card reveal group" style="transition-delay:200ms">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl" style="background:#FFF7ED;">🏗️</div>
          <div>
            <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Construção Civil e Imobiliário</div>
            <h3 class="text-lg font-bold text-primary mb-2">Qualificação e follow-up de leads</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              IA qualifica leads inbound, envia propostas, faz follow-up automático e só passa para o corretor quando o cliente está aquecido.
            </p>
            <div class="mt-4 flex gap-2 flex-wrap">
              <span class="px-2 py-1 rounded-md text-xs font-medium text-orange-700 bg-orange-50">+3x conversão</span>
              <span class="px-2 py-1 rounded-md text-xs font-medium text-orange-700 bg-orange-50">Zero lead frio</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Case 4 -->
      <div class="card reveal group" style="transition-delay:300ms">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl" style="background:#F5F3FF;">📦</div>
          <div>
            <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Logística e Transporte</div>
            <h3 class="text-lg font-bold text-primary mb-2">Rastreamento e comunicação ativa</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Clientes recebem updates de entrega em tempo real via WhatsApp. Ocorrências são abertas e resolvidas automaticamente sem ligações.
            </p>
            <div class="mt-4 flex gap-2 flex-wrap">
              <span class="px-2 py-1 rounded-md text-xs font-medium text-violet-700 bg-violet-50">-70% ligações</span>
              <span class="px-2 py-1 rounded-md text-xs font-medium text-violet-700 bg-violet-50">NPS +40pts</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Case 5 -->
      <div class="card reveal group" style="transition-delay:400ms">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl" style="background:#ECFDF5;">📚</div>
          <div>
            <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Educação e Cursos</div>
            <h3 class="text-lg font-bold text-primary mb-2">Onboarding e engajamento automático</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Alunos recebem trilhas personalizadas, lembretes de aula, suporte via IA e sequências de reengajamento — tudo sem esforço manual.
            </p>
            <div class="mt-4 flex gap-2 flex-wrap">
              <span class="px-2 py-1 rounded-md text-xs font-medium text-emerald-700 bg-emerald-50">+50% conclusão</span>
              <span class="px-2 py-1 rounded-md text-xs font-medium text-emerald-700 bg-emerald-50">Churn -35%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Case 6 -->
      <div class="card reveal group" style="transition-delay:500ms">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl" style="background:#FFF1F2;">⚙️</div>
          <div>
            <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Indústria e Serviços</div>
            <h3 class="text-lg font-bold text-primary mb-2">Backoffice e financeiro automatizados</h3>
            <p class="text-gray-500 text-sm leading-relaxed">
              Emissão de NF, cobranças, relatórios gerenciais, aprovações de compra e gestão de fornecedores integrados e sem digitação manual.
            </p>
            <div class="mt-4 flex gap-2 flex-wrap">
              <span class="px-2 py-1 rounded-md text-xs font-medium text-rose-700 bg-rose-50">-90% erros</span>
              <span class="px-2 py-1 rounded-md text-xs font-medium text-rose-700 bg-rose-50">+60h/mês</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="text-center mt-12 reveal">
      <p class="text-gray-500 text-sm">Não viu o seu segmento?
        <a href="https://wa.me/<%= whatsapp.number %>?text=<%= encodeURIComponent(whatsapp.message) %>" target="_blank" rel="noopener" class="text-accent font-semibold hover:text-accent-hover">Fale com nosso time →</a>
      </p>
    </div>

  </div>
</section>

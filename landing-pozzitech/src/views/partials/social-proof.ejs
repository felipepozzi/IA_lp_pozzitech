<section id="social-proof" class="py-16 border-y" style="background:#111827;border-color:rgba(255,255,255,0.06);">
  <div class="max-w-container mx-auto px-6">

    <!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mb-16 reveal">
      <div class="text-center">
        <div class="text-4xl font-extrabold text-white mb-1">+120</div>
        <div class="text-sm text-white/50">Empresas atendidas</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-extrabold gradient-text mb-1">40%</div>
        <div class="text-sm text-white/50">Redução média de custos</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-extrabold text-white mb-1">3x</div>
        <div class="text-sm text-white/50">Mais velocidade operacional</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-extrabold text-highlight mb-1">98%</div>
        <div class="text-sm text-white/50">Clientes satisfeitos</div>
      </div>
    </div>

    <!-- Testimonials -->
    <div class="mb-10 text-center reveal">
      <p class="text-sm text-white/40 font-medium uppercase tracking-widest">O que nossos clientes dizem</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% testimonials.forEach((t, i) => { %>
      <div class="reveal card-dark" style="transition-delay: <%= i * 100 %>ms">
        <!-- Stars -->
        <div class="flex gap-1 mb-4">
          <% for(let s = 0; s < t.rating; s++) { %>
          <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <% } %>
        </div>
        <p class="text-white/70 text-sm leading-relaxed mb-5">"<%= t.text %>"</p>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white flex-shrink-0" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
            <%= t.avatar %>
          </div>
          <div>
            <div class="text-sm font-semibold text-white"><%= t.name %></div>
            <div class="text-xs text-white/40"><%= t.company %></div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

  </div>
</section>

<section id="results" class="py-24 lg:py-32 bg-surface">
  <div class="max-w-container mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Copy -->
      <div class="reveal">
        <div class="section-tag">Resultados reais</div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-primary leading-tight tracking-tight mb-6">
          Números que provam o impacto da automação
        </h2>
        <p class="text-lg text-gray-500 leading-relaxed mb-8">
          Nossos clientes não apenas economizam tempo — eles transformam o modelo operacional da empresa e criam vantagem competitiva duradoura.
        </p>
        <a href="#offer" class="btn-primary">Quero esses resultados</a>
      </div>

      <!-- Right: Metrics grid -->
      <div class="grid grid-cols-2 gap-5 reveal">

        <div class="rounded-card p-6 border border-gray-100 shadow-card" style="background:linear-gradient(135deg,#F5F3FF,#EDE9FE);">
          <div class="text-4xl font-extrabold mb-1" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">-40%</div>
          <div class="text-sm font-semibold text-gray-700 mb-1">Redução de custos *</div>
          <div class="text-xs text-gray-400">em processos operacionais</div>
        </div>

        <div class="rounded-card p-6 border border-gray-100 shadow-card" style="background:linear-gradient(135deg,#ECFDF5,#D1FAE5);">
          <div class="text-4xl font-extrabold text-emerald-600 mb-1">+120h</div>
          <div class="text-sm font-semibold text-gray-700 mb-1">Horas recuperadas *</div>
          <div class="text-xs text-gray-400">por mês em média</div>
        </div>

        <div class="rounded-card p-6 border border-gray-100 shadow-card" style="background:linear-gradient(135deg,#FFF7ED,#FFEDD5);">
          <div class="text-4xl font-extrabold text-orange-500 mb-1">3x</div>
          <div class="text-sm font-semibold text-gray-700 mb-1">Mais velocidade *</div>
          <div class="text-xs text-gray-400">no atendimento ao cliente</div>
        </div>

        <div class="rounded-card p-6 border border-gray-100 shadow-card" style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE);">
          <div class="text-4xl font-extrabold text-blue-600 mb-1">6 sem.</div>
          <div class="text-sm font-semibold text-gray-700 mb-1">Tempo de retorno *</div>
          <div class="text-xs text-gray-400">do investimento médio</div>
        </div>

        <div class="col-span-2 rounded-card p-6 border border-gray-100 shadow-card" style="background:linear-gradient(135deg,#0A0A0A,#111827);">
          <div class="flex items-center justify-between">
            <div>
              <div class="text-4xl font-extrabold text-white mb-1">80%</div>
              <div class="text-sm font-semibold text-white/70 mb-1">Das consultas resolvidas pela IA *</div>
              <div class="text-xs text-white/40">sem intervenção humana, em média</div>
            </div>
            <div class="flex gap-1">
              <% for(let i = 0; i < 5; i++) { %>
              <svg class="w-6 h-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </div>

    <p class="text-xs text-gray-400 text-center mt-10 reveal">
      * Métricas baseadas em resultados observados em nossos projetos e dados de mercado (McKinsey, Forrester, Gartner). Resultados variam conforme o negócio.
    </p>

  </div>
</section>

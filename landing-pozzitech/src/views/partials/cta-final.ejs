<section id="cta-final" class="py-24 lg:py-32 relative overflow-hidden" style="background:#0A0A0A;">

  <!-- Background effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:800px;height:400px;background:radial-gradient(ellipse,rgba(79,70,229,0.15) 0%,transparent 70%);"></div>
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:60px 60px;"></div>
  </div>

  <div class="max-w-container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mx-auto text-center reveal">

      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-highlight/30 text-highlight text-sm font-medium mb-8" style="background:rgba(34,197,94,0.08);">
        <span class="w-2 h-2 bg-highlight rounded-full animate-pulse"></span>
        Só atendemos 5 novas empresas por mês
      </div>

      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
        Seu concorrente já automatizou. <span class="gradient-text">Você vai esperar até quando?</span>
      </h2>

      <p class="text-xl text-white/50 leading-relaxed mb-10 max-w-2xl mx-auto">
        Agende um diagnóstico gratuito e sem compromisso. Em 30 minutos, entendemos juntos onde a inteligência artificial pode gerar mais resultado para você.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href="<%= calendly.url %>" target="_blank" rel="noopener" class="btn-primary text-base px-8 py-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Marque um horário gratuito
        </a>
        <a href="https://wa.me/<%= whatsapp.number %>?text=<%= encodeURIComponent(whatsapp.message) %>"
           target="_blank" rel="noopener"
           class="btn-whatsapp text-base px-8 py-4">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Falar no WhatsApp
        </a>
      </div>

      <!-- Social proof mini -->
      <div class="flex items-center justify-center gap-3 text-sm text-white/40">
        <span>Diagnóstico gratuito · Sem compromisso · 30 minutos</span>
      </div>

    </div>
  </div>
</section>

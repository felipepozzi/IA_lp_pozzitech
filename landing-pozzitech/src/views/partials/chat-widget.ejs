<!-- Chat Widget -->

<!-- Janela de chat -->
<div id="chat-window"
  class="hidden z-50 rounded-2xl shadow-2xl overflow-hidden"
  style="position:fixed;bottom:96px;right:16px;width:340px;height:520px;background:#111827;border:1px solid rgba(255,255,255,0.1);flex-direction:column;">

  <!-- Header -->
  <div class="flex items-center gap-3 px-4 py-3 flex-shrink-0"
    style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
    <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
      <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24">
        <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <p class="text-white font-semibold text-sm leading-tight">Assistente PozziTech</p>
      <div class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
        <p class="text-white/60 text-xs">Online agora</p>
      </div>
    </div>
    <button id="chat-close-btn" class="text-white/60 hover:text-white transition-colors p-1" aria-label="Fechar chat">
      <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
  </div>

  <!-- Mensagens -->
  <div id="chat-messages" class="p-4 space-y-3"
    style="flex:1 1 0;min-height:0;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.1) transparent;">
  </div>

  <!-- Chips de opções -->
  <div id="chat-chips" class="hidden px-3 pt-2 pb-3 flex-wrap gap-2 flex-shrink-0"
    style="border-top:1px solid rgba(255,255,255,0.05);">
  </div>

  <!-- Input -->
  <div id="chat-input-area" class="p-3 flex-shrink-0" style="border-top:1px solid rgba(255,255,255,0.08);">
    <div class="flex gap-2">
      <input
        id="chat-input"
        type="text"
        placeholder="Digite sua mensagem..."
        class="flex-1 rounded-xl px-4 py-2.5 text-sm text-white placeholder-white/40 outline-none transition-opacity"
        style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);"
        maxlength="500"
        autocomplete="off"
      />
      <button id="chat-send"
        class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 transition-all duration-200 hover:scale-105 disabled:opacity-40 disabled:cursor-not-allowed"
        style="background:linear-gradient(135deg,#4F46E5,#7C3AED);"
        aria-label="Enviar mensagem">
        <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </div>
  </div>

</div>

<!-- Botão toggle (ao lado do WhatsApp) -->
<button id="chat-toggle"
  class="z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all duration-200 hover:scale-110 relative"
  style="position:fixed;bottom:24px;right:88px;background:linear-gradient(135deg,#4F46E5,#7C3AED);box-shadow:0 4px 20px rgba(79,70,229,0.4);"
  aria-label="Abrir assistente">
  <svg id="chat-icon-open" class="w-7 h-7 fill-white" viewBox="0 0 24 24">
    <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
  </svg>
  <svg id="chat-icon-close" class="w-7 h-7 fill-white hidden" viewBox="0 0 24 24">
    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
  </svg>
  <!-- Pulse de atenção (some após abrir) -->
  <span id="chat-pulse" class="absolute inset-0 rounded-full animate-ping opacity-30" style="background:#4F46E5;"></span>
</button>

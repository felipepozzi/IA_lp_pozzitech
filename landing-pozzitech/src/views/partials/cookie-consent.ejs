<!-- Cookie Consent Banner (LGPD) -->
<div id="cookie-banner"
     class="hidden fixed bottom-0 left-0 right-0 z-50 p-4 sm:p-6"
     role="dialog"
     aria-live="polite"
     aria-label="Aviso de cookies">
  <div class="max-w-container mx-auto">
    <div class="rounded-card p-5 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4"
         style="background:#1a1f2e;border:1px solid rgba(79,70,229,0.3);box-shadow:0 -4px 40px rgba(0,0,0,0.4);">

      <!-- Icon + Text -->
      <div class="flex items-start gap-3 flex-1 min-w-0">
        <span class="text-2xl flex-shrink-0" aria-hidden="true">🍪</span>
        <div>
          <p class="text-sm text-white/90 leading-relaxed">
            Utilizamos cookies para melhorar sua experiência, analisar o tráfego do site e personalizar conteúdo, conforme nossa
            <a href="#" class="underline text-accent-light hover:text-white transition-colors">Política de Privacidade</a>.
            Ao continuar navegando, você concorda com o uso de cookies.
          </p>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <button id="cookie-reject"
                class="text-sm text-white/50 hover:text-white transition-colors px-4 py-2 rounded-lg"
                style="background:rgba(255,255,255,0.06);">
          Recusar
        </button>
        <button id="cookie-accept"
                class="btn-primary text-sm px-5 py-2">
          Aceitar
        </button>
      </div>

    </div>
  </div>
</div>

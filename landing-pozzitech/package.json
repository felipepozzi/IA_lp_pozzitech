{
  "name": "landing-pozzitech",
  "version": "1.0.0",
  "description": "Landing page PozziTech - Automação com IA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./src/public/css/style.css --watch",
    "postinstall": "npm run build:css"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@supabase/supabase-js": "^2.101.0",
    "compression": "^1.7.4",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "tailwindcss": "^3.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

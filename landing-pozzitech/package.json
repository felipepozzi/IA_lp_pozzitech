{
  "name": "landing-pozzitech",
  "version": "1.0.0",
  "description": "Landing page PozziTech - Automação com IA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./src/public/css/style.css --watch",
    "postinstall": "npm run build:css"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9",
    "compression": "^1.7.4",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
